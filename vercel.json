{
  "version": 2,
  "buildCommand": "npx prisma generate",
  "functions": {
    "api/index.js": {
      "runtime": "nodejs20.x",
      "includeFiles": [
        "public/**",
        "node_modules/swagger-ui-dist/**"
      ]
    }
  },
  "routes": [
    {
      "src": "/(.*)",
      "dest": "src/index.js"
    }
  ]
}
